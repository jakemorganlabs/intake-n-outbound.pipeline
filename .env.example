# Copy to .env and fill in values. Never commit .env to git.
# On a VPS, run scripts/setup-vps.sh to be prompted for each key interactively.

# Database (Postgres)
DATABASE_URL=postgresql://postgres@localhost:5432/intake_pipeline

# Webhook — HMAC signature verification from public form (e.g. Tally)
WEBHOOK_SECRET=change-me-in-production

# Model API — DeepInfra OpenAI-compatible endpoint for Gemma 4 inference
INFERENCE_API_KEY=di-...
MODEL_API_KEY=di-...
MODEL_ID=google/gemma-4-26B-A4B-it
INFERENCE_BASE_URL=https://api.deepinfra.com/v1/openai

# Search API — Brave Search web research (fail-open if missing)
SEARCH_API_KEY=BS...

# HOT tier — Slack alert + HubSpot CRM contact
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
HUBSPOT_API_KEY=pat-na1-...

# WARM tier — Google Sheets append
GOOGLE_SHEETS_API_KEY=...
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms
