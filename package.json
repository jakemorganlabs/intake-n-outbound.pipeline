{
  "name": "intake-outbound-pipeline",
  "version": "1.0.1",
  "description": "Lead-intelligence pipeline: intake, enrichment, scoring, and routing",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "migrate": "npx tsx src/db/migrate.ts",
    "validate:schemas": "npx tsx scripts/validate-schemas.ts",
    "start": "npx tsx src/server.ts",
    "smoke": "npx tsx scripts/smoke.ts",
    "eval": "npx tsx evals/run.ts",
    "pipeline": "npx tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "pg": "^8.12.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "dotenv": "^17.4.2",
    "hono": "^4.12.25"
  }
}
