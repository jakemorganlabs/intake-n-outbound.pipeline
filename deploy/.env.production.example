# deploy/.env.production.example
# Copy to deploy/.env.production on the target VPS and replace every __REPLACE_ME__ with real values.
# NEVER commit the real .env.production file.

# ===== Postgres =====
POSTGRES_USER=intake_user
POSTGRES_PASSWORD=__REPLACE_ME__
POSTGRES_DB=intake_pipeline

# n8n Postgres connection (n8n prefixes its DB env vars with DB_POSTGRESDB_)
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=intake_pipeline
DB_POSTGRESDB_USER=intake_user
DB_POSTGRESDB_PASSWORD=__REPLACE_ME__

# ===== n8n =====
N8N_ENCRYPTION_KEY=__REPLACE_ME__
N8N_HOST=localhost
WEBHOOK_URL=https://intake.jakemorganlabs.dev/
GENERIC_TIMEZONE=America/Los_Angeles

# ===== Cloudflare Tunnel =====
# Create a remote-managed tunnel at https://one.dash.cloudflare.com/
TUNNEL_TOKEN=__REPLACE_ME__

# ===== Inference — DeepInfra-hosted Google Gemma (tailored; do not change model) =====
# Google Gemma 4 via DeepInfra OpenAI-compatible endpoint (§15, §19)
INFERENCE_API_KEY=__REPLACE_ME__
MODEL_API_KEY=__REPLACE_ME__
MODEL_ID=google/gemma-4-26B-A4B-it
INFERENCE_BASE_URL=https://api.deepinfra.com/v1/openai

# ===== Web Research =====
# Brave Search API key (free tier available)
SEARCH_API_KEY=__REPLACE_ME__

# ===== HOT Tier — Slack + HubSpot =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/__REPLACE_ME__
HUBSPOT_API_KEY=__REPLACE_ME__

# ===== WARM Tier — Google Sheets =====
GOOGLE_SHEETS_API_KEY=__REPLACE_ME__
GOOGLE_SHEET_ID=__REPLACE_ME__
GOOGLE_SHEET_RANGE=warm_leads!A1

# ===== Inbound Webhook HMAC =====
WEBHOOK_SECRET=__REPLACE_ME__
